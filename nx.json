{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "origin/main",
    "targetDefaults": {
        "composer-install": {
            "executor": "nx:run-commands",
            "options": {
                "command": "composer install",
                "cwd": "{projectRoot}"
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts build",
                "cwd": "{projectRoot}",
                "output-path": "dist",
                "blocks-manifest": ""
            },
            "inputs": ["buildInputs"],
            "outputs": ["{projectRoot}/dist"],
            "cache": true
        },
        "start": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts start",
                "cwd": "{projectRoot}",
                "output-path": "dist",
                "blocks-manifest": ""
            },
            "continuous": true
        },
        "test-integration": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env run tests-cli composer run test",
                "cwd": "{projectRoot}",
                "configuration": "vendor/bcew-monorepo/phpunit-config/phpunit.integration.xml"
            },
            "dependsOn": ["composer-install", "wp-env-start"]
        },
        "test-e2e": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts test-playwright",
                "cwd": "{projectRoot}"
            },
            "dependsOn": ["build", "wp-env-start"]
        },
        "test-screenshot": {
            "executor": "nx:run-commands",
            "options": {
                "command": "UPDATE_SNAPSHOTS=none PROJECT_PATH={projectRoot} docker compose up --exit-code-from=playwright"
            },
            "parallelism": false,
            "dependsOn": ["build", "wp-env-start"]
        },
        "test-screenshot-generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "UPDATE_SNAPSHOTS=all PROJECT_PATH={projectRoot} docker compose up --exit-code-from=playwright"
            },
            "parallelism": false,
            "dependsOn": ["build", "wp-env-start"]
        },
        "wp-env-start": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env start",
                "cwd": "{projectRoot}",
                "xdebug": "coverage"
            }
        },
        "wp-env-clean": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env clean",
                "cwd": "{projectRoot}"
            }
        },
        "wp-env-stop": {
            "executor": "nx:run-commands",
            "options": {
                "command": "sh -c 's=$(wp-env status --json 2>/dev/null); echo \"$s\" | grep -q uninitialized && exit 0; echo \"$s\" | grep -qF \"\\\"status\\\":\\\"stopped\\\"\" && exit 0; exec wp-env stop'",
                "cwd": "{projectRoot}"
            }
        }
    },
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "buildInputs": [
            "{projectRoot}/**",
            "!{projectRoot}/dist/**",
            "{workspaceRoot}/package.json",
            "{workspaceRoot}/pnpm-lock.json"
        ],
        "sharedGlobals": []
    },
    "release": {
        "changelog": {
            "workspaceChangelog": {
                "createRelease": "github"
            }
        }
    },
    "analytics": true
}
