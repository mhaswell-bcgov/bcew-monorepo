{
    "core": "WordPress/WordPress#6.7.2",
    "phpVersion": "7.4",
    "themes": [
        <% if(parentTheme !== "none") { %>
        ".",
        "bcgov/<%= parentTheme %>"
        <% } else { %>
        "."
        <% } %>
    ],
    "config": {
        "WP_AUTO_UPDATE_CORE": false
    },
    "port": <%= wpEnvPort %>,
    "testsPort": <%= wpEnvPort + 1 %>,
    "lifecycleScripts": {
        "afterStart": "wp-env run tests-cli wp theme activate <%= slug %>"
    }
}
