{
    "name": "bcgov-bcew-monorepo",
    "version": "0.0.1",
    "private": true,
    "description": "A monorepo for BC government WordPress plugins and themes",
    "author": "govwordpress@gov.bc.ca",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "bcgov",
        "wordpress",
        "monorepo",
        "plugins",
        "themes"
    ],
    "homepage": "https://github.com/bcgov/bcew-monorepo",
    "repository": {
        "type": "git",
        "url": "https://github.com/bcgov/bcew-monorepo"
    },
    "bugs": "https://github.com/bcgov/bcew-monorepo/issues",
    "engines": {
        "node": "^24.12.0"
    },
    "workspaces": [
        "themes/*",
        "plugins/*",
        "packages/*"
    ],
    "dependencies": {
        "@nx/devkit": "catalog:",
        "@nx/plugin": "catalog:",
        "@playwright/test": "catalog:",
        "@wordpress/env": "catalog:",
        "@wordpress/scripts": "catalog:",
        "@wordpress/stylelint-config": "catalog:",
        "chokidar-cli": "catalog:",
        "concurrently": "catalog:",
        "eslint-plugin-playwright": "catalog:",
        "eslint-plugin-prefer-arrow": "catalog:",
        "js-beautify": "catalog:",
        "nx": "catalog:",
        "vitepress": "catalog:"
    },
    "peerDependencies": {
        "@swc-node/register": "catalog:",
        "@swc/cli": "catalog:",
        "@swc/core": "catalog:",
        "@swc/helpers": "catalog:",
        "@types/jest": "catalog:",
        "@types/node": "catalog:",
        "prettier": "catalog:",
        "react": "catalog:",
        "tslib": "catalog:",
        "typescript": "catalog:"
    },
    "scripts": {
        "composer-install": "npx nx run-many -t composer-install",
        "build": "npx nx run-many -t build",
        "start": "npx nx run-many -t start",
        "test-e2e": "npx nx run-many -t test-e2e",
        "test-integration": "npx nx run-many -t test-integration",
        "test-screenshot": "npx nx run-many -t test-screenshot",
        "test-screenshot-generate": "npx nx run-many -t test-screenshot-generate",
        "test-unit-js": "npx nx run-many -t test-unit-js",
        "test-unit-php": "npx nx run-many -t test-unit-php",
        "lint": "pnpm run lint-js && pnpm run lint-css && pnpm run lint-php && pnpm run lint-md && pnpm run lint-pkg-json",
        "lint-js": "wp-scripts lint-js",
        "fix-js": "wp-scripts lint-js --fix",
        "lint-css": "wp-scripts lint-style",
        "fix-css": "wp-scripts lint-style --fix",
        "lint-php": "composer run lint-php",
        "fix-php": "composer run fix-php",
        "fix-html": "npx js-beautify --html {themes,plugins}/**/{parts,patterns,templates}/**/*",
        "lint-md": "wp-scripts lint-md-docs",
        "fix-md": "wp-scripts lint-md-docs --fix",
        "lint-pkg-json": "wp-scripts lint-pkg-json",
        "check-engines": "wp-scripts check-engines",
        "check-licenses": "wp-scripts check-licenses --prod",
        "wp-env": "wp-env",
        "wp-env-clean": "npx nx run-many -t wp-env-clean",
        "wp-env-stop": "npx nx run-many -t wp-env-stop",
        "docs:sync": "node tools/sync-docs.mjs",
        "docs:sync:watch": "chokidar \"plugins/**/docs/**\" \"themes/**/docs/**\" \"tools/sync-docs.mjs\" -c \"node tools/sync-docs.mjs\" -d 300",
        "docs:dev": "pnpm docs:sync && concurrently -k \"pnpm run docs:sync:watch\" \"vitepress dev docs\"",
        "docs:build": "pnpm docs:sync && vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "release": "npx nx g monorepo:release-tag"
    }
}
