{
    "name": "bcgov-plugin/bcew-blocks",
    "description": "Plugin containing blocks intended to be used with the Design System WordPress Theme suite of products.",
    "type": "wordpress-plugin",
    "license": "Apache-2.0",
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/phpunit-config",
            "options": {
                "symlink": false
            }
        }
    ],
    "require-dev": {
        "bcew-monorepo/phpunit-config": "*",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Bcgov\\BcgovWordpressBlocks\\": "src/",
            "Bcgov\\BcgovWordpressBlocks\\Test\\": "tests/php/"
        }
    },
    "scripts": {
        "test": [
            "./vendor/bin/phpunit"
        ]
    }
}
