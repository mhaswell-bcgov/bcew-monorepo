{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "bcew-blocks/cards",
    "version": "0.1.8",
    "title": "Cards",
    "category": "media",
    "icon": "grid-view",
    "description": "A row of cards.",
    "attributes": {
        "cardCount": {
            "type": "number",
            "default": 2
        },
        "contentType": {
            "type": "string",
            "default": "icon-text"
        },
        "boxShadow": {
            "type": "boolean",
            "default": false
        },
        "showParagraph": {
            "type": "boolean",
            "default": true
        },
        "showList": {
            "type": "boolean",
            "default": true
        }
    },
    "supports": {
        "html": false
    },
    "textdomain": "bcew-blocks",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css"
}
