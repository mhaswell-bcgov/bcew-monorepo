{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "bcew-blocks/icon-text-block",
    "version": "0.0.9",
    "title": "Icon Text Block",
    "category": "media",
    "icon": "media-document",
    "description": "",
    "example": {},
    "attributes": {
        "layout": {
            "type": "string",
            "default": "icon-left"
        },
        "boxShadow": {
            "type": "boolean",
            "default": false
        },
        "showParagraph": {
            "type": "boolean",
            "default": true
        },
        "showList": {
            "type": "boolean",
            "default": true
        },
        "hideEmptyList": {
            "type": "boolean",
            "default": true
        }
    },
    "providesContext": {
        "bcew-blocks/hideEmptyList": "hideEmptyList"
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "anchor": true,
        "color": {
            "text": true,
            "background": true,
            "gradients": false
        },
        "typography": {
            "fontSize": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        }
    },
    "textdomain": "bcew-blocks",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": ["file:./style-index.css", "file:./index.css"]
}
