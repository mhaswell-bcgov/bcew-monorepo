{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "bcew-blocks/media-text-layout",
    "version": "0.0.4",
    "title": "Media & Text Layout",
    "category": "media",
    "keywords": ["media", "image", "text", "layout", "design system"],
    "icon": "format-image",
    "description": "Set media and words side-by-side with adjustable layout.",
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "anchor": true,
        "color": {
            "text": true,
            "background": true,
            "gradients": false
        },
        "typography": {
            "fontSize": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        }
    },
    "attributes": {
        "imageId": { "type": "number" },
        "imagePosition": {
            "type": "string",
            "default": "left"
        },
        "layoutRatio": {
            "type": "object",
            "default": {
                "image": 25,
                "content": 75
            }
        },
        "characterLimit": {
            "type": "number",
            "default": 200
        },
        "showParagraph": {
            "type": "boolean",
            "default": true
        },
        "showList": {
            "type": "boolean",
            "default": true
        },
        "hideEmptyList": {
            "type": "boolean",
            "default": true
        }
    },
    "providesContext": {
        "bcew-blocks/hideEmptyList": "hideEmptyList"
    },
    "textdomain": "bcew-blocks",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}
