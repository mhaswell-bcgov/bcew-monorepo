{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Belleville Terminal Child Theme",

    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "belleville-primary",
                    "color": "#234075",
                    "name": "Belleville Primary"
                },
                {
                    "slug": "belleville-secondary",
                    "color": "#00BBDA",
                    "name": "Belleville Secondary"
                },
                {
                    "slug": "belleville-tertiary",
                    "color": "#6BCCE3",
                    "name": "Belleville Tertiary"
                },
                {
                    "slug": "accent-primary",
                    "color": "#00BBDA",
                    "name": "Accent Primary"
                }
            ]
        }
    },

    "styles": {
        "css": ".belleville-search-page .wp-block-post-excerpt__excerpt{margin-top:0!important;}.belleville-search-page .wp-block-post-title{margin-top:0!important;}.belleville-search-page .wp-block-separator{padding-top:0!important;padding-bottom:0!important;}",
        "elements": {
            "h1": {
                "typography": {
                    "fontSize": "36px"
                },
                "spacing": {
                    "margin": {
                        "top": "1.5rem!important",
                        "bottom": "1.5rem!important"
                    }
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "32px"
                },
                "spacing": {
                    "margin": {
                        "top": "3rem!important"
                    }
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "28px"
                },
                "spacing": {
                    "margin": {
                        "top": "1rem!important"
                    }
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "24px"
                },
                "spacing": {
                    "margin": {
                        "top": "1rem!important"
                    }
                }
            }
        },

        "blocks": {
            "core/list": {
                "typography": {
                    "fontSize": "1rem",
                    "lineHeight": "1.688rem"
                },
                "spacing": {
                    "margin": {
                        "top": "1rem!important",
                        "bottom": "0"
                    }
                }
            },
            "core/buttons": {
                "layout": {
                    "type": "flex",
                    "justifyContent": "left"
                },
                "spacing": {
                    "margin": {
                        "top": "1rem!important"
                    }
                }
            },
            "core/button": {
                "typography": {
                    "textAlign": "left"
                }
            },
            "core/paragraph": {
                "spacing": {
                    "margin": {
                        "top": "1rem!important",
                        "bottom": "0"
                    }
                }
            },
            "core/separator": {
                "dimensions": {
                    "maxWidth": "70rem"
                },
                "spacing": {
                    "padding": {
                        "top": "1.25rem",
                        "bottom": "1.25rem"
                    }
                },
                "border": {
                    "color": "var(--dswp-surface-color-border-medium, #D8D8D8)",
                    "top": {
                        "style": "none"
                    },
                    "right": {
                        "style": "none"
                    },
                    "left": {
                        "style": "none"
                    },
                    "bottom": {
                        "width": "1px",
                        "style": "solid"
                    }
                }
            }
        }
    }
}
